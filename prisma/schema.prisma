// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

enum Role {
  SUPER_ADMIN
  SOCIETY_ADMIN
  SUB_ADMIN
  RESIDENT
  SECURITY_GUARD
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum AmenityStatus {
  ACTIVE
  INACTIVE
}

enum PaymentStatus {
  NOT_REQUIRED
  PENDING
  PAID
  REFUNDED
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum MaintenanceStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
}

enum VisitorStatus {
  APPROVED
  INSIDE
  LEFT
  DENIED
}

enum GateEntryStatus {
  PENDING
  APPROVED
  DENIED
  INSIDE
  LEFT
}

enum EntryMethod {
  QR_SCAN
  MANUAL
  PRE_APPROVED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      Role     @default(RESIDENT)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apartment    Apartment?    @relation("ApartmentResident")
  notices      Notice[]
  complaints   Complaint[]
  bookings     Booking[]
  visitors     Visitor[]
  guardProfile GuardProfile?
  gateEntries  GateEntry[]   @relation("GuardEntries")
  adminSociety Society?      @relation("SocietyAdmin")
  maintenances Maintenance[]
}

model GuardProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  societyId      String
  society        Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  gateAssignment String?
  shift          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Society {
  id               String            @id @default(cuid())
  name             String
  address          String
  city             String
  adminId          String            @unique
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  admin            User              @relation("SocietyAdmin", fields: [adminId], references: [id])
  buildings        Building[]
  amenities        Amenity[]
  notices          Notice[]
  complaints       Complaint[]
  visitors         Visitor[]
  maintenances     Maintenance[]
  expectedVisitors ExpectedVisitor[]
  gateEntries      GateEntry[]
  gateQRs          GateQR[]
  guards           GuardProfile[]
}

model Building {
  id         String      @id @default(cuid())
  name       String
  societyId  String
  subAdminId String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  society    Society     @relation(fields: [societyId], references: [id], onDelete: Cascade)
  apartments Apartment[]
}

model Apartment {
  id            String            @id @default(cuid())
  number        String
  floor         Int
  buildingId    String
  residentId    String?           @unique
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  building      Building          @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  resident      User?             @relation("ApartmentResident", fields: [residentId], references: [id])
  familyMembers FamilyMember[]
  vehicles      Vehicle[]
  inviteTokens  InviteToken[]
  visitors      Visitor[]
  gateEntries   GateEntry[]
  maintenances  Maintenance[]
}

model FamilyMember {
  id          String    @id @default(cuid())
  name        String
  relation    String
  phone       String?
  dateOfBirth DateTime?
  apartmentId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
}

model Vehicle {
  id          String    @id @default(cuid())
  plateNumber String    @unique
  type        String
  brand       String?
  color       String?
  apartmentId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
}

model Amenity {
  id              String        @id @default(cuid())
  name            String
  description     String?
  capacity        Int           @default(10)
  location        String?
  availableDays   String        @default("Mon,Tue,Wed,Thu,Fri,Sat,Sun")
  openTime        String        @default("06:00")
  closeTime       String        @default("22:00")
  slotDuration    Int           @default(60)
  advanceBookDays Int           @default(7)
  isPaid          Boolean       @default(false)
  pricePerSlot    Decimal?      @db.Decimal(10, 2)
  status          AmenityStatus @default(ACTIVE)
  societyId       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  society         Society       @relation(fields: [societyId], references: [id], onDelete: Cascade)
  bookings        Booking[]
}

model Booking {
  id            String        @id @default(cuid())
  amenityId     String
  userId        String
  date          DateTime
  startTime     String
  endTime       String
  purpose       String?
  guestCount    Int           @default(1)
  status        BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(NOT_REQUIRED)
  amountPaid    Decimal?      @db.Decimal(10, 2)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  amenity       Amenity       @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notice {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String
  societyId String
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  society   Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  creator   User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
}

model Complaint {
  id            String          @id @default(cuid())
  title         String
  description   String
  category      String
  status        ComplaintStatus @default(OPEN)
  photo         String?
  adminResponse String?
  userId        String
  societyId     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  society       Society         @relation(fields: [societyId], references: [id], onDelete: Cascade)
}

model Visitor {
  id           String        @id @default(cuid())
  name         String
  phone        String?
  vehiclePlate String?
  purpose      String
  flatNumber   String
  status       VisitorStatus @default(INSIDE)
  isExpected   Boolean       @default(false)
  expectedDate DateTime?
  userId       String
  societyId    String
  apartmentId  String?
  approvedById String?
  entryTime    DateTime      @default(now())
  exitTime     DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  society      Society       @relation(fields: [societyId], references: [id], onDelete: Cascade)
  apartment    Apartment?    @relation(fields: [apartmentId], references: [id])
}

model ExpectedVisitor {
  id              String   @id @default(cuid())
  name            String
  phone           String?
  vehiclePlate    String?
  purpose         String
  expectedDate    DateTime
  residentId      String
  societyId       String
  apartmentNumber String
  isVisited       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  society         Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
}

model Maintenance {
  id                String            @id @default(cuid())
  amount            Float
  month             Int
  year              Int
  dueDate           DateTime
  status            MaintenanceStatus @default(PENDING)
  userId            String
  user              User              @relation(fields: [userId], references: [id])
  societyId         String
  society           Society           @relation(fields: [societyId], references: [id])
  apartmentId       String
  apartment         Apartment         @relation(fields: [apartmentId], references: [id])
  razorpayOrderId   String?
  razorpayPaymentId String?
  paidAt            DateTime?
  receiptUrl        String?
  penaltyAmount     Float?            @default(0)
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model InviteToken {
  id          String    @id @default(cuid())
  token       String    @unique
  apartmentId String
  expiresAt   DateTime
  used        Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
}

model GateEntry {
  id            String          @id @default(cuid())
  visitorName   String
  visitorPhone  String
  purpose       String
  vehicleNumber String?
  photo         String?
  duration      String?
  entryMethod   EntryMethod     @default(MANUAL)
  apartmentId   String
  apartment     Apartment       @relation(fields: [apartmentId], references: [id])
  societyId     String
  society       Society         @relation(fields: [societyId], references: [id])
  guardId       String?
  guard         User?           @relation("GuardEntries", fields: [guardId], references: [id])
  status        GateEntryStatus @default(PENDING)
  entryTime     DateTime?
  exitTime      DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model GateQR {
  id        String   @id @default(cuid())
  societyId String
  society   Society  @relation(fields: [societyId], references: [id])
  gateName  String
  token     String   @unique @default(cuid())
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

